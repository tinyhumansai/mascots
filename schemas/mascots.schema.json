{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tinyhumansai/mascots/main/schemas/mascots.schema.json",
  "title": "OpenHuman Mascots Manifest",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "mascots"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["repository", "branch", "commit"],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        }
      }
    },
    "mascots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "status", "tags", "stateEngine", "files"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["ready", "draft"]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "stateEngine": {
            "type": "object",
            "required": ["visemeCodes", "states", "idlePoseCycle"],
            "additionalProperties": false,
            "properties": {
              "visemeCodes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "states": {
                "type": "object",
                "required": ["idle", "thinking"],
                "additionalProperties": false,
                "properties": {
                  "idle": {
                    "type": "string",
                    "minLength": 1
                  },
                  "thinking": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "idlePoseCycle": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "channels": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "object",
                  "required": ["key", "values"],
                  "additionalProperties": false,
                  "properties": {
                    "key": {
                      "type": "string",
                      "minLength": 1
                    },
                    "enum": {
                      "type": "string",
                      "minLength": 1
                    },
                    "label": {
                      "type": "string"
                    },
                    "values": {
                      "type": "array",
                      "minItems": 1,
                      "uniqueItems": true,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "default": {
                      "type": "string",
                      "minLength": 1
                    },
                    "cycle": {
                      "type": "object",
                      "required": ["enabled"],
                      "additionalProperties": false,
                      "properties": {
                        "enabled": {
                          "type": "boolean"
                        },
                        "intervalMs": {
                          "type": "integer",
                          "minimum": 0
                        },
                        "order": {
                          "type": "string",
                          "enum": ["random", "sequential"]
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["role", "path", "url", "sha256", "bytes"],
              "additionalProperties": false,
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "role": {
                        "const": "runtime"
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "path": {
                        "type": "string",
                        "pattern": "^(?:[a-z0-9]+(?:-[a-z0-9]+)*/)*[a-z][A-Za-z0-9]*\\.riv$"
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "role": {
                        "const": "source"
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "path": {
                        "type": "string",
                        "pattern": "^(?:[a-z0-9]+(?:-[a-z0-9]+)*/)*[a-z][A-Za-z0-9]*\\.rev$"
                      }
                    }
                  }
                }
              ],
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["runtime", "source", "thumbnail", "preview"]
                },
                "path": {
                  "type": "string"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                },
                "bytes": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  }
}
